# Vorlage für die Produktions-Geheimnisse.
# So benutzen:
#   1. Diese Datei auf dem SERVER zu ".env" kopieren:  cp .env.example .env
#   2. Echte Werte eintragen.
#   3. docker compose up -d   (Compose liest .env automatisch)
#
# WICHTIG: Die echte ".env" wird per .gitignore NICHT eingecheckt.

# Langes Zufallsgeheimnis (mind. 32 Zeichen). Erzeugen z. B. mit:
#   openssl rand -base64 48
JWT_SECRET=hier-ein-langes-zufaelliges-geheimnis-eintragen

# Initial-Admin (wird nur beim allerersten Start angelegt, solange die DB leer ist).
ADMIN_EMAIL=admin@qubic.org
ADMIN_PASSWORD=hier-ein-sicheres-startpasswort
