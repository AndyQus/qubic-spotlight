@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject SpotlightApi Api
@inject Localizer L
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="@AppBarStyle">
        <a href="/" class="qs-logo">
            <LogoBanner IsDark="_isDarkMode" />
        </a>
        <MudSpacer />

        <!-- Navigation: nur ab Tablet/Desktop sichtbar -->
        <div class="d-none d-md-flex align-center">
            @NavLinks(false)

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            <!-- Sprachumschalter -->
            <MudButtonGroup Size="Size.Small" Variant="Variant.Text">
                <MudButton Color="@(L.Lang == "en" ? Color.Primary : Color.Inherit)" OnClick='@(() => SetLangAsync("en"))'>EN</MudButton>
                <MudButton Color="@(L.Lang == "de" ? Color.Primary : Color.Inherit)" OnClick='@(() => SetLangAsync("de"))'>DE</MudButton>
            </MudButtonGroup>

            <!-- Dark/Light -->
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" Title='@L["header.theme"]' OnClick="ToggleDarkAsync" />
        </div>

        <!-- Mobil: Dark/Light + Burger-Button -->
        <div class="d-flex d-md-none align-center">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" Title='@L["header.theme"]' OnClick="ToggleDarkAsync" />
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                           Edge="Edge.End" OnClick="ToggleDrawer" />
        </div>
    </MudAppBar>

    <!-- Mobil-Navigation als ausklappbares Burger-Menü (nur < md) -->
    <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.Right" Elevation="2"
               Variant="DrawerVariant.Temporary" ClipMode="DrawerClipMode.Never" Class="d-md-none">
        <MudNavMenu Class="pa-2">
            @NavLinks(true)

            <MudDivider Class="my-2" />

            <div class="d-flex align-center px-2">
                <MudButtonGroup Size="Size.Small" Variant="Variant.Text">
                    <MudButton Color="@(L.Lang == "en" ? Color.Primary : Color.Inherit)" OnClick='@(() => SetLangAsync("en"))'>EN</MudButton>
                    <MudButton Color="@(L.Lang == "de" ? Color.Primary : Color.Inherit)" OnClick='@(() => SetLangAsync("de"))'>DE</MudButton>
                </MudButtonGroup>
            </div>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
            <FooterComponent />
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An error has occurred.
    <a href="" class="reload">Reload</a>
</div>

@code {
    private bool _isDarkMode = true;
    private bool _drawerOpen;
    private const string DarkKey = "qspot_dark";

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void CloseDrawer() => _drawerOpen = false;

    // Gemeinsame Navigationslinks für Desktop-AppBar (Buttons) und mobiles
    // Burger-Menü (NavLinks, schließen den Drawer beim Klick).
    private RenderFragment NavLinks(bool mobile) =>@<text>
        @Link("/", Icons.Material.Filled.Dashboard, L["nav.dashboard"], mobile, match: NavLinkMatch.All)
        @Link("/pulse", Icons.Material.Filled.Bolt, L["nav.pulse"], mobile)
        <AuthorizeView>
            <Authorized>
                @Link("/admin", Icons.Material.Filled.Campaign, L["nav.ads"], mobile)
                @Link("/admin/embed", Icons.Material.Filled.Code, L["nav.embed"], mobile)
                <AuthorizeView Roles="Admin" Context="adminCtx">
                    @Link("/admin/users", Icons.Material.Filled.People, L["nav.users"], mobile)
                </AuthorizeView>
                @Link("/account", Icons.Material.Filled.AccountCircle, L["nav.account"], mobile)
                @if (mobile)
                {
                    <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="@(async () => { CloseDrawer(); await LogoutAsync(); })">@L["nav.logout"]</MudNavLink>
                }
                else
                {
                    <MudButton OnClick="LogoutAsync" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Logout">@L["nav.logout"]</MudButton>
                }
            </Authorized>
            <NotAuthorized>
                @if (mobile)
                {
                    <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login" OnClick="CloseDrawer">@L["nav.login"]</MudNavLink>
                }
                else
                {
                    <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login">@L["nav.login"]</MudButton>
                }
            </NotAuthorized>
        </AuthorizeView>
    </text>;

    // Einzelner Navigationspunkt – Button (Desktop) oder NavLink (Mobil).
    private RenderFragment Link(string href, string icon, string text, bool mobile, NavLinkMatch match = NavLinkMatch.Prefix) =>@<text>
        @if (mobile)
        {
            <MudNavLink Href="@href" Match="@match" Icon="@icon" OnClick="CloseDrawer">@text</MudNavLink>
        }
        else
        {
            <MudButton Href="@href" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@icon">@text</MudButton>
        }
    </text>;

    private string AppBarStyle => _isDarkMode
        ? "background-color:#0d1117; color:#e0e0e0;"
        : "background-color:#f5f5f5; color:#1a1a2e;";

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7e6fff",
            Secondary = "#1192a8",
            Tertiary = "#1192a8",
            Background = "#ffffff",
            BackgroundGray = "#f0f2f5",
            Surface = "#f7f9fc",
            AppbarBackground = "#f5f5f5",
            AppbarText = "#1a1a2e",
            TextPrimary = "#1a1a2e",
            TextSecondary = "#566073",
            LinesDefault = "#dfe3ea",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7e6fff",
            Secondary = "#4EE0FC",
            Tertiary = "#4EE0FC",
            Background = "#101820",
            AppbarBackground = "#0d1117",
            AppbarText = "#e0e0e0",
            Surface = "#1a2332",
            DrawerBackground = "#0d1117",
        }
    };

    protected override void OnInitialized() => L.Changed += OnChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await L.InitAsync();
        var dark = await JS.InvokeAsync<string?>("localStorage.getItem", DarkKey);
        if (dark is "false") _isDarkMode = false;
        StateHasChanged();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task SetLangAsync(string lang) => await L.SetAsync(lang);

    private async Task ToggleDarkAsync()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", DarkKey, _isDarkMode ? "true" : "false");
    }

    private async Task LogoutAsync()
    {
        await Api.LogoutAsync();
        ((JwtAuthStateProvider)AuthProvider).NotifyChanged();
        Nav.NavigateTo("/");
    }

    public void Dispose() => L.Changed -= OnChanged;
}
