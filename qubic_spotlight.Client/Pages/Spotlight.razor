@page "/"
@page "/spotlight"
@page "/pulse"
@inherits LocalizedComponentBase
@inject SpotlightApi Api
@inject IJSRuntime JS

<PageTitle>Qubic Spotlight — @L["spotlight.title"]</PageTitle>
<script src="/spotlight.js"

        data-mode="slide-panel"
        data-position="right"
        data-interval="5000"
        data-theme="auto"
        data-bg="linear-gradient(90deg, #f59e0b, #ea580c, #f59e0b)"
        data-max="10"
        data-closable="true"
        async></script>

<div class="spotlight-page">

@* Qubic-Netzwerk-Statistikleiste (wie auf dem Dashboard).
   Auf dem Handy via CSS-order hinter die Anzeigen verschoben. *@
@if (_stats is not null)
{
    <div class="qs-stats">
        @foreach (var (label, value) in StatTiles())
        {
            <div class="qs-stat">
                <div class="label">@label</div>
                <div class="value">@value</div>
            </div>
        }
    </div>
}

<div class="spotlight-feed">

<div class="spotlight-head">
 <div class="spotlight-sort">
        <button class="spotlight-seg @(_sort == "new" ? "on" : "")" @onclick='() => SetSortAsync("new")'>@L["spotlight.sort.new"]</button>
        <button class="spotlight-seg @(_sort == "top" ? "on" : "")" @onclick='() => SetSortAsync("top")'>@L["spotlight.sort.top"]</button>
    </div>

     @if (_ecosystems.Count > 0)
    {
        <div class="spotlight-filter">
            <button class="spotlight-chip @(_eco is null ? "on" : "")" @onclick="() => SetEcoAsync(null)">@L["spotlight.filter.all"]</button>
            @foreach (var eco in _ecosystems)
            {
                <button class="spotlight-chip @(string.Equals(_eco, eco, StringComparison.OrdinalIgnoreCase) ? "on" : "")"
                        @onclick="() => SetEcoAsync(eco)">@eco</button>
            }
        </div>
    }
</div>

<MudTabs Elevation="0" Rounded="true" Border="false" ApplyEffectsToContainer="true"
         ActivePanelIndex="_tab" ActivePanelIndexChanged="OnTabChangedAsync"
         PanelClass="pt-4" Class="spotlight-tabs">
    <MudTabPanel Text="@L["spotlight.tab.grid"]" Icon="@Icons.Material.Filled.ViewModule">
        @if (_ads.Count > 0)
        {
            <div class="qs-ads">
                @foreach (var ad in _ads)
                {
                    <div class="qs-ad-card spotlight-clickable" @onclick="() => OpenAd(ad)">
                        @if (!string.IsNullOrEmpty(ad.ImageUrl))
                        {
                            <div class="qs-ad-media">
                                <img src="@ad.ImageUrl" alt="" onerror="this.closest('.qs-ad-media').remove()" />
                            </div>
                        }
                        <div class="qs-ad-body">
                            <span class="qs-ad-title">@ad.Title</span>
                            <p>@ad.Description</p>
                            @if (!string.IsNullOrEmpty(ad.Ecosystem))
                            {
                                <span class="qs-ad-eco">@ad.Ecosystem</span>
                            }
                            @Votes(ad)
                        </div>
                    </div>
                }
            </div>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>

    <MudTabPanel Text="@L["spotlight.tab.stream"]" Icon="@Icons.Material.Filled.ViewStream">
        @if (_ads.Count > 0)
        {
            <div class="spotlight-stream">
                @foreach (var ad in _ads) { @StreamPost(ad) }
            </div>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>

    <MudTabPanel Text="@L["spotlight.tab.bento"]" Icon="@Icons.Material.Filled.GridView">
        @if (_ads.Count > 0)
        {
            <div class="spotlight-bento">
                @for (var i = 0; i < _ads.Count; i++)
                {
                    var ad = _ads[i];
                    <div class="spotlight-tile spotlight-clickable @BentoClass(i)" @onclick="() => OpenAd(ad)">@TileInner(ad)</div>
                }
            </div>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>

    <MudTabPanel Text="@L["spotlight.tab.magazine"]" Icon="@Icons.Material.Filled.Article">
        @if (_ads.Count > 0)
        {
            var hero = _ads[0];
            <div class="spotlight-mag">
                <div class="spotlight-mag-hero spotlight-clickable" @onclick="() => OpenAd(hero)">@HeroInner(hero)</div>
                @if (_ads.Count > 1)
                {
                    <div class="spotlight-mag-rest">
                        @foreach (var ad in _ads.Skip(1))
                        {
                            <div class="spotlight-tile spotlight-clickable" @onclick="() => OpenAd(ad)">@TileInner(ad)</div>
                        }
                    </div>
                }
            </div>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>

    <MudTabPanel Text="@L["spotlight.tab.wall"]" Icon="@Icons.Material.Filled.Dashboard">
        @if (_ads.Count > 0)
        {
            <div class="spotlight-wall">
                @foreach (var ad in _ads)
                {
                    <div class="spotlight-wall-item spotlight-clickable" @onclick="() => OpenAd(ad)">@TileInner(ad)</div>
                }
            </div>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>

    <MudTabPanel Text="@L["spotlight.tab.slide"]" Icon="@Icons.Material.Filled.Slideshow">
        @if (_ads.Count > 0)
        {
            <MudCarousel Class="mud-width-full" Style="height:220px; border-radius:12px;"
                         ShowArrows="true" ShowBullets="true" AutoCycle="true"
                         AutoCycleTime="TimeSpan.FromSeconds(5)" TData="PublicAd" ItemsSource="_ads">
                <ItemTemplate Context="ad">
                    <div class="spotlight-clickable" @onclick="() => OpenAd(ad)"
                         style="display:flex; height:100%; background:var(--mud-palette-surface);">
                        @if (!string.IsNullOrEmpty(ad.ImageUrl))
                        {
                            <div class="spotlight-slide-media" style="flex:0 0 300px;">
                                <img src="@ad.ImageUrl" alt="" style="width:300px; height:100%; object-fit:cover;"
                                     onerror="this.closest('.spotlight-slide-media').remove()" />
                            </div>
                        }
                        <div style="padding:24px; display:flex; flex-direction:column; justify-content:center; min-width:0;">
                            <h2 style="margin:0 0 8px; color:var(--mud-palette-text-primary); font-weight:500;">@ad.Title</h2>
                            <p style="margin:0; color:var(--mud-palette-text-secondary); max-width:560px;">@ad.Description</p>
                            @if (!string.IsNullOrEmpty(ad.Ecosystem))
                            {
                                <span class="qs-ad-eco">@ad.Ecosystem</span>
                            }
                            @Votes(ad)
                        </div>
                    </div>
                </ItemTemplate>
            </MudCarousel>
        }
        else if (_loaded) { @Empty }
    </MudTabPanel>
</MudTabs>

</div>@* /spotlight-feed *@
</div>@* /spotlight-page *@

@code {
    private const string TabKey = "qspot_spotlight_tab";
    private const string SortKey = "qspot_spotlight_sort";
    private const string EcoKey = "qspot_spotlight_eco";
    private const string VoterKey = "qspot_voter";
    private const string VisitKey = "qspot_visited";

    private QubicStats? _stats;
    private long _visits;
    private QubicBlockStats? _blocks;
    private List<PricePoint> _priceHistory = new();
    private List<PublicAd> _ads = new();
    private List<string> _ecosystems = new();
    private int _tab;
    private string _sort = "new";
    private string? _eco;
    private string? _voterId;
    private bool _loaded;

    // Hält die Kacheln (Price, Chart, Blocks) live: holt im Server-Takt (60s)
    // die gecachten Werte nach. Beim Verlassen der Seite gestoppt (Dispose).
    private static readonly TimeSpan RefreshInterval = TimeSpan.FromSeconds(60);
    private PeriodicTimer? _refreshTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Gemerkte Einstellungen aus dem localStorage laden.
        var tab = await GetItem(TabKey);
        if (int.TryParse(tab, out var t) && t is >= 0 and <= 5) _tab = t;
        var sort = await GetItem(SortKey);
        if (sort is "new" or "top") _sort = sort;
        _eco = await GetItem(EcoKey);
        if (string.IsNullOrWhiteSpace(_eco)) _eco = null;

        // Anonyme Besucher-Kennung für die Vote-Begrenzung (einmalig erzeugen).
        _voterId = await GetItem(VoterKey);
        if (string.IsNullOrWhiteSpace(_voterId))
        {
            _voterId = await JS.InvokeAsync<string>("crypto.randomUUID");
            await SetItem(VoterKey, _voterId);
        }

        // Seitenbesuch zählen — pro Browser-Session genau einmal (sessionStorage),
        // sonst nur den aktuellen Gesamtwert lesen.
        var visited = await GetSessionItem(VisitKey);
        if (string.IsNullOrEmpty(visited))
        {
            _visits = await Api.RecordVisitAsync();
            await SetSessionItem(VisitKey, "1");
        }
        else
        {
            _visits = await Api.GetVisitCountAsync();
        }

        await RefreshStatsAsync();
        _ecosystems = await Api.GetFeedEcosystemsAsync();
        await LoadFeedAsync();
        _loaded = true;
        StateHasChanged();

        // Ab jetzt im Server-Takt (60s) nachladen, ohne Seiten-Reload.
        _ = RunRefreshLoopAsync();
    }

    // Holt die gecachten Live-Werte (Price, Chart, Blocks) vom Server.
    private async Task RefreshStatsAsync()
    {
        _stats = await Api.GetStatsAsync();
        _blocks = await Api.GetBlockStatsAsync();
        _priceHistory = await Api.GetPriceHistoryAsync();
    }

    private async Task RunRefreshLoopAsync()
    {
        _refreshTimer = new PeriodicTimer(RefreshInterval);
        try
        {
            while (await _refreshTimer.WaitForNextTickAsync())
            {
                await RefreshStatsAsync();
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { /* Seite verlassen */ }
    }

    public override void Dispose()
    {
        _refreshTimer?.Dispose();
        base.Dispose();
    }

    private async Task LoadFeedAsync()
        => _ads = await Api.GetFeedAsync(_sort, _eco, _voterId);

    private async Task SetSortAsync(string sort)
    {
        if (_sort == sort) return;
        _sort = sort;
        await SetItem(SortKey, sort);
        await LoadFeedAsync();
        StateHasChanged();
    }

    private async Task SetEcoAsync(string? eco)
    {
        _eco = eco;
        await SetItem(EcoKey, eco ?? "");
        await LoadFeedAsync();
        StateHasChanged();
    }

    private async Task OnTabChangedAsync(int index)
    {
        _tab = index;
        await SetItem(TabKey, index.ToString());
    }

    private async Task VoteAsync(PublicAd ad, int value)
    {
        // Erneuter Klick auf die aktive Stimme nimmt sie zurück (Toggle).
        var desired = ad.MyVote == value ? 0 : value;
        var res = await Api.VoteAsync(ad.Id, desired, _voterId);
        if (res is null) return;
        ad.LikeCount = res.LikeCount;
        ad.DislikeCount = res.DislikeCount;
        ad.MyVote = res.MyVote;
        StateHasChanged();
    }

    private Task<string?> GetItem(string key) => JS.InvokeAsync<string?>("localStorage.getItem", key).AsTask();
    private Task SetItem(string key, string value) => JS.InvokeVoidAsync("localStorage.setItem", key, value).AsTask();

    private Task<string?> GetSessionItem(string key) => JS.InvokeAsync<string?>("sessionStorage.getItem", key).AsTask();
    private Task SetSessionItem(string key, string value) => JS.InvokeVoidAsync("sessionStorage.setItem", key, value).AsTask();

    private static string ClickUrl(PublicAd ad) => $"/api/ads/{ad.Id}/click";

    // Öffnet den Artikel in einem neuen Tab (zählt serverseitig den Klick).
    // Wird beim Klick auf eine Anzeige-Karte ausgelöst; Vote-Buttons stoppen
    // die Weiterleitung per stopPropagation.
    private ValueTask OpenAd(PublicAd ad)
        => JS.InvokeVoidAsync("open", ClickUrl(ad), "_blank", "noopener");

    private static string BentoClass(int i)
        => i == 0 ? "tile-lg" : (i % 6 == 0 ? "tile-wide" : (i % 8 == 5 ? "tile-tall" : ""));

    private string Ago(DateTime utc)
    {
        if (utc == default) return "";
        var mins = (DateTime.UtcNow - utc).TotalMinutes;
        if (mins < 1) return L["spotlight.justNow"];
        if (mins < 60) return L.T("spotlight.minutesAgo", (int)mins);
        var hrs = mins / 60;
        if (hrs < 24) return L.T("spotlight.hoursAgo", (int)hrs);
        return L.T("spotlight.daysAgo", (int)(hrs / 24));
    }

    private IEnumerable<(string, RenderFragment)> StatTiles()
    {
        var s = _stats!;
        yield return (L["stat.price"], Text(Format.Price(s.Price)));
        yield return (L["stat.marketcap"], Text(Format.Money(s.MarketCap)));
        // Supply für später aufgehoben — Platz nutzt jetzt der 24h-Kurschart.
        // yield return (L["stat.supply"], Text(Format.Compact(s.CirculatingSupply)));
        yield return (L["stat.priceChart"], PriceChart());
        yield return (L["stat.epoch"], Text(s.Epoch.ToString()));
        yield return (L["stat.burned"], Text(Format.Compact(s.BurnedQus)));
        yield return (L["stat.dogeBlocks"], Blocks(b => b.DogeTotalConfirmed, b => b.DogeCurrentEpochConfirmed));
        yield return (L["stat.ltcBlocks"], Blocks(b => b.LtcTotalConfirmed, b => b.LtcCurrentEpochConfirmed));
        yield return (L["stat.visits"], Text(Format.Number(_visits)));
    }

    private static RenderFragment Text(string value) =>@<text>@value</text>;

    // Block-Kachelwert: "Total (aktuelle Epoche)", z. B. "321 (18)".
    // Der Klammerwert übernimmt die Farbe der Kachel-Überschrift.
    // Solange die Pool-Daten fehlen, "–" anzeigen.
    private RenderFragment Blocks(Func<QubicBlockStats, int> total, Func<QubicBlockStats, int> epoch)
    {
        if (_blocks is null) return Text("–");
        var t = Format.Number(total(_blocks));
        var e = epoch(_blocks);
        if (e <= 0) return Text(t);
        return @<text>@t <span class="qs-stat-epoch">(@Format.Number(e))</span></text>;
    }

    // 24h-Kurschart als kompaktes Inline-SVG (Sparkline). Bewusst klein —
    // grün wenn der Kurs über 24h gestiegen ist, sonst rot. Der Klammerwert
    // (Farbe der Überschrift) zeigt die 24h-Veränderung in %, der Tooltip
    // zusätzlich Min/Max.
    private RenderFragment PriceChart()
    {
        var pts = _priceHistory;
        if (pts.Count < 2) return Text("–");

        var inv = System.Globalization.CultureInfo.InvariantCulture;
        const double w = 120, h = 28, pad = 2;
        double min = pts.Min(p => p.Price), max = pts.Max(p => p.Price);
        double range = max - min;
        if (range <= 0) range = Math.Abs(max) > 0 ? Math.Abs(max) : 1;

        double X(int i) => pad + (w - 2 * pad) * i / (pts.Count - 1);
        double Y(double v) => pad + (h - 2 * pad) * (1 - (v - min) / range);

        var coords = string.Join(" ",
            pts.Select((p, i) => $"{X(i).ToString("0.#", inv)},{Y(p.Price).ToString("0.#", inv)}"));

        double first = pts[0].Price, last = pts[^1].Price;
        var up = last >= first;
        var stroke = up ? "#22c55e" : "#ef4444";
        var changePct = first > 0 ? (last - first) / first * 100 : 0;
        var changeLabel = (changePct >= 0 ? "+" : "") + changePct.ToString("0.0", inv) + "%";
        var tip = $"{L["stat.priceChart"]}: {changeLabel}  ·  ↑ {Format.Price(max)}  ↓ {Format.Price(min)}";

        return @<text>
            <svg class="qs-spark" viewBox="0 0 120 28" preserveAspectRatio="none" role="img"
                 aria-label="@tip">
                <title>@tip</title>
                <polyline points="@coords" fill="none" stroke="@stroke" stroke-width="1.5"
                          stroke-linejoin="round" stroke-linecap="round" />
            </svg>
            <span class="qs-spark-change" style="color:@stroke;" title="@tip">@changeLabel</span>
        </text>;
    }

    // ── Wiederverwendbare Bausteine ───────────────────────────────────────────
    private RenderFragment Empty =>@<MudText Class="pa-8" Style="color:var(--mud-palette-text-secondary);">@L["spotlight.noAds"]</MudText>;

    private RenderFragment Meta(PublicAd ad) =>@<text>
        @if (!string.IsNullOrEmpty(ad.Ecosystem))
        {
            <div class="spotlight-meta">
                <span class="qs-ad-eco">@ad.Ecosystem</span>
            </div>
        }
    </text>;

    // Vote-Leiste. Klicks auf 👍/👎 dürfen die Karte nicht öffnen → stopPropagation.
    // Das Artikeldatum steht rechts (statt des früheren "Öffnen"-Links).
    private RenderFragment Votes(PublicAd ad) =>@<text>
        <div class="spotlight-votes" @onclick:stopPropagation="true">
            <button class="spotlight-vote up @(ad.MyVote == 1 ? "on" : "")" title="@L["spotlight.like"]"
                    @onclick="() => VoteAsync(ad, 1)">👍 <span class="cnt">@ad.LikeCount</span></button>
            <button class="spotlight-vote down @(ad.MyVote == -1 ? "on" : "")" title="@L["spotlight.dislike"]"
                    @onclick="() => VoteAsync(ad, -1)">👎 <span class="cnt">@ad.DislikeCount</span></button>
            <span class="spotlight-clicks" title="@L["spotlight.clicks"]">👁 <span class="cnt">@ad.ClickCount</span></span>
            <span class="spotlight-time">@Ago(ad.CreatedAt)</span>
        </div>
    </text>;

    // Breite Karte für den Stream. Ganze Karte klickbar → öffnet den Artikel.
    private RenderFragment StreamPost(PublicAd ad) =>@<div class="spotlight-post spotlight-clickable" @onclick="() => OpenAd(ad)">
        @if (!string.IsNullOrEmpty(ad.ImageUrl))
        {
            <div class="spotlight-post-media">
                <img src="@ad.ImageUrl" alt="" onerror="this.closest('.spotlight-post-media').remove()" />
            </div>
        }
        <div class="spotlight-post-body">
            @Meta(ad)
            <span class="spotlight-post-title">@ad.Title</span>
            <p class="spotlight-post-text">@ad.Description</p>
            @Votes(ad)
        </div>
    </div>;

    // Kompakte Kachel für Bento / Wand / Magazin-Rest. Ganze Kachel klickbar.
    private RenderFragment TileInner(PublicAd ad) =>@<text>
        @if (!string.IsNullOrEmpty(ad.ImageUrl))
        {
            <div class="spotlight-tile-media">
                <img src="@ad.ImageUrl" alt="" onerror="this.closest('.spotlight-tile-media').remove()" />
            </div>
        }
        <div class="spotlight-tile-body">
            @Meta(ad)
            <span class="spotlight-tile-title">@ad.Title</span>
            <p class="spotlight-tile-text">@ad.Description</p>
            @Votes(ad)
        </div>
    </text>;

    // Großer Aufmacher fürs Magazin.
    private RenderFragment HeroInner(PublicAd ad) =>@<text>
        @if (!string.IsNullOrEmpty(ad.ImageUrl))
        {
            <div class="spotlight-hero-media">
                <img src="@ad.ImageUrl" alt="" onerror="this.closest('.spotlight-hero-media').remove()" />
            </div>
        }
        <div class="spotlight-hero-body">
            <span class="spotlight-badge">@L["spotlight.featured"]</span>
            @Meta(ad)
            <span class="spotlight-hero-title">@ad.Title</span>
            <p class="spotlight-hero-text">@ad.Description</p>
            @Votes(ad)
        </div>
    </text>;
}
