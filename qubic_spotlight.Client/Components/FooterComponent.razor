@using System.Reflection
@inherits LocalizedComponentBase

<MudAlert ContentAlignment="HorizontalAlignment.Center"
          Severity="Severity.Warning"
          Variant="Variant.Text"
          Class="mt-6 mb-2"
          Style="padding:4px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; justify-content:center; align-items:baseline; gap:4px;">
        <MudText Typo="Typo.caption"><b>@L["footer.disclaimer.label"]</b></MudText>
        <MudText Typo="Typo.caption">@L["footer.disclaimer.beta"]</MudText>
        <MudText Typo="Typo.caption">@L["footer.disclaimer.data"]</MudText>
        <MudLink Color="Color.Tertiary" Href="https://rpc.qubic.org" Target="_blank"
                 Underline="Underline.Hover" Style="font-size:small;">rpc.qubic.org</MudLink>
        <MudText Typo="Typo.caption">,</MudText>
        <MudText Typo="Typo.caption">@L["footer.disclaimer.data2"]</MudText>
        <MudLink Color="Color.Tertiary" Href="https://doge.qubic.tools" Target="_blank"
                 Underline="Underline.Hover" Style="font-size:small;">doge.qubic.tools</MudLink>
        <MudText Typo="Typo.caption">.</MudText>
        <MudText Typo="Typo.caption">@L["footer.disclaimer.noguarantee"]</MudText>
        <MudText Typo="Typo.caption"><strong>@L["footer.disclaimer.demo"]</strong></MudText>
    </div>
</MudAlert>

<MudPaper Class="mt-2 pa-1 mb-2 pt-3" Elevation="0" Square="true">
    <MudGrid Class="align-items-center" Justify="Justify.SpaceBetween">

        <MudItem xs="12" md="4" Class="d-flex align-center justify-center justify-md-start">
            <MudImage Src="/qubic-icon.svg" Height="22" Width="22" />
            <MudText Typo="Typo.caption">
                &nbsp;&copy; @DateTime.Now.Year @L["footer.sponsored"]
            </MudText>
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex flex-wrap justify-center gap-2">
            @for (int i = 0; i < LinkItems.Count; i++)
            {
                var item = LinkItems[i];
                <MudLink Color="Color.Tertiary" Href="@item.To" Target="_blank" rel="noreferrer"
                         Underline="Underline.Hover" Style="font-size:small;">@item.Label</MudLink>
                @if (i < LinkItems.Count - 1)
                {
                    <MudText Typo="Typo.caption">&#x2022;</MudText>
                }
            }
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex justify-center justify-md-end">
            <MudText Typo="Typo.caption">v.@_version (BETA)</MudText>
        </MudItem>

    </MudGrid>
</MudPaper>

@code {
    private string _version = "0.1.0";

    private record FooterLinkItem(string Label, string To);

    private static readonly List<FooterLinkItem> LinkItems =
    [
        new("Qubic.org", "https://qubic.org"),
        new("GitHub", "https://github.com/AndyQus/qubic-spotlight"),
        new("Terms of Service", "https://qubic.org/terms-of-service"),
        new("Privacy Policy", "https://qubic.org/privacy-policy")
    ];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        var full = Assembly.GetExecutingAssembly()
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()
            ?.InformationalVersion ?? "0.1.0";
        _version = full.Split('+')[0];
    }
}
