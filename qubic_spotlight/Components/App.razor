<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <meta name="description" content="Qubic Spotlight - Werbung & Showcase aus dem Qubic-Ökosystem" />
    <meta name="application-name" content="Qubic Spotlight" />
    <meta name="theme-color" content="#0d1117" />

    <!-- Favicon: Qubic-Logomark in Qubic-Orange (SVG für moderne Browser, PNG-Fallback) -->
    <link rel="icon" type="image/svg+xml" href="/qubic-icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />

    <!-- PWA / Installierbarkeit -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- iOS: Home-Screen-Installation ("Zum Home-Bildschirm") -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Spotlight" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <!-- Qubic-Markenschrift (qubic.org) für das Logo -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="site.css" rel="stylesheet" />
    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
</head>
<body>
    <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="spotlight-preview.js"></script>
    <script src="panel-toggle.js"></script>
</body>
</html>
