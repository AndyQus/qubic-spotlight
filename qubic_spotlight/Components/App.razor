<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <!-- ===== Grundlegende SEO-Meta-Tags ===== -->
    <title>Qubic Spotlight – Advertising &amp; Showcase from the Qubic ecosystem</title>
    <meta name="description" content="Qubic Spotlight showcases projects, tools and advertisements from the Qubic ecosystem. Discover the Qubic network, its community projects and the latest showcases all in one place." />
    <meta name="keywords" content="Qubic, Qubic Spotlight, Qubic ecosystem, Qubic projects, Qubic advertising, Qubic showcase, Qubic community, crypto, blockchain, QUBIC coin" />
    <meta name="author" content="AndyQus" />
    <meta name="application-name" content="Qubic Spotlight" />
    <meta name="theme-color" content="#0d1117" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow" />

    <!-- Sprache & kanonische URL (verhindert Duplicate-Content) -->
    <meta http-equiv="content-language" content="en" />
    <link rel="canonical" href="https://spotlight.qubic.tools/" />

    <!-- ===== Open Graph (Facebook, LinkedIn, WhatsApp, Telegram) ===== -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Qubic Spotlight" />
    <meta property="og:title" content="Qubic Spotlight – Advertising &amp; Showcase from the Qubic ecosystem" />
    <meta property="og:description" content="Discover projects, tools and advertisements from the Qubic ecosystem – bundled in Qubic Spotlight." />
    <meta property="og:url" content="https://spotlight.qubic.tools/" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://spotlight.qubic.tools/og-image.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Qubic Spotlight – Advertising & Showcase from the Qubic ecosystem" />

    <!-- ===== Twitter / X Card ===== -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Qubic Spotlight – Advertising &amp; Showcase from the Qubic ecosystem" />
    <meta name="twitter:description" content="Discover projects, tools and advertisements from the Qubic ecosystem – bundled in Qubic Spotlight." />
    <meta name="twitter:image" content="https://spotlight.qubic.tools/og-image.png" />
    <meta name="twitter:image:alt" content="Qubic Spotlight – Advertising & Showcase from the Qubic ecosystem" />

    <!-- ===== Strukturierte Daten (Schema.org / JSON-LD) ===== -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebSite",
      "name": "Qubic Spotlight",
      "alternateName": "Qubic Spotlight – Advertising & Showcase",
      "url": "https://spotlight.qubic.tools/",
      "description": "Qubic Spotlight showcases projects, tools and advertisements from the Qubic ecosystem.",
      "inLanguage": "en",
      "author": {
        "@@type": "Person",
        "name": "AndyQus"
      },
      "publisher": {
        "@@type": "Organization",
        "name": "Qubic Spotlight",
        "logo": {
          "@@type": "ImageObject",
          "url": "https://spotlight.qubic.tools/icon-512.png"
        }
      }
    }
    </script>

    <!-- Favicon: Qubic-Logomark in Qubic-Orange (SVG für moderne Browser, PNG-Fallback) -->
    <link rel="icon" type="image/svg+xml" href="/qubic-icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />

    <!-- PWA / Installierbarkeit -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- iOS: Home-Screen-Installation ("Zum Home-Bildschirm") -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Spotlight" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <!-- Qubic-Markenschrift (qubic.org) für das Logo -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="site.css" rel="stylesheet" />
    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
</head>
<body>
    <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="spotlight-preview.js"></script>
    <script src="panel-toggle.js"></script>
</body>
</html>
