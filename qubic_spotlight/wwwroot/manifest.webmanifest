    { "src": "/icon-512.png", "type": "image/png", "sizes": "512x512" },
    { "src": "/icon-512.png", "type": "image/png", "sizes": "512x512", "purpose": "maskable" },
    { "src": "/qubic-icon.svg", "type": "image/svg+xml", "sizes": "any" }
  ]
}
