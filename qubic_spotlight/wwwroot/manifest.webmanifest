{
  "name": "Qubic Spotlight",
  "short_name": "Spotlight",
  "description": "Werbung & Showcase aus dem Qubic-Ökosystem",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
